{
  "name": "pixel-tracker",
  "version": "1.86.0",
  "scripts": {
    "start": "export NODE_OPTIONS=--openssl-legacy-provider && expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "eject": "expo eject",
    "test": "jest --watchAll --env=jsdom",
    "test:ci": "jest --env=jsdom",
    "disclaimer": "echo \"export default \\`$(yarn licenses generate-disclaimer | sed 's/\\`/\\\\`/g')\\`\" > disclaimer.js",
    "build:ios:dev": "npx eas-cli build -p ios --local --profile=development",
    "build:android:dev": "npx eas-cli build -p android --local --profile=development",
    "build:ios:preview": "npx eas-cli build -p ios --local --profile=preview",
    "build:android:preview": "npx eas-cli build -p android --local --profile=preview",
    "build:ios:prod": "npx eas-cli build -p ios --local --profile=production",
    "build:android:prod": "npx eas-cli build -p android --local --profile=production",
    "submit:preview": "npx eas-cli submit -p android --path $(ls -t *.aab | head -1) && npx eas-cli submit -p ios --path $(ls -t *.ipa | head -1)",
    "submit:prod": "npx eas-cli submit -p android --path $(ls -t *.aab | head -1) && npx eas-cli submit -p ios --path $(ls -t *.ipa | head -1)",
    "build:preview": "yarn build:ios:preview && yarn build:android:preview",
    "build:prod": "yarn build:ios:prod && yarn build:android:prod",
    "translate-app": "node scripts/generate-translations-app.js",
    "type-check": "tsc"
  },
  "jest": {
    "preset": "jest-expo",
    "testPathIgnorePatterns": [
      "./__tests__/utils.ts"
    ],
    "collectCoverage": false,
    "collectCoverageFrom": [
      "./hooks/*.{js,jsx,ts,tsx}",
      "./helpers/*.{js,jsx,ts,tsx}",
      "!**/coverage/**",
      "!**/node_modules/**",
      "!**/babel.config.js",
      "!**/jest.setup.js"
    ]
  },
  "dependencies": {
    "@expo/webpack-config": "^19.0.1",
    "@gorhom/bottom-sheet": "^5.2.8",
    "@legendapp/motion": "^2.2.0",
    "@pchmn/expo-material3-theme": "^1.4.0",
    "@react-native-async-storage/async-storage": "~3.0.1",
    "@react-native-community/datetimepicker": "9.1.0",
    "@react-native-community/hooks": "^100.1.0",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/native": "^7.1.33",
    "@react-navigation/native-stack": "^7.14.5",
    "chroma-js": "^3.2.0",
    "dayjs": "^1.11.7",
    "expo": "~55.0.7",
    "expo-app-loading": "~2.1.0",
    "expo-application": "~55.0.10",
    "expo-asset": "~55.0.9",
    "expo-constants": "~55.0.8",
    "expo-dev-client": "~55.0.17",
    "expo-device": "~55.0.10",
    "expo-document-picker": "~55.0.9",
    "expo-file-system": "~55.0.11",
    "expo-font": "~55.0.4",
    "expo-haptics": "~55.0.9",
    "expo-linear-gradient": "~55.0.9",
    "expo-linking": "~55.0.7",
    "expo-local-authentication": "~55.0.9",
    "expo-localization": "~55.0.9",
    "expo-notifications": "~55.0.13",
    "expo-sharing": "~55.0.12",
    "expo-splash-screen": "~55.0.11",
    "expo-status-bar": "~55.0.4",
    "expo-store-review": "~55.0.9",
    "expo-system-ui": "~55.0.10",
    "expo-updates": "~55.0.14",
    "expo-web-browser": "~55.0.10",
    "i18n-js": "^4.5.3",
    "lodash": "^4.17.21",
    "lucide-react-native": "^0.577.0",
    "node-addon-api": "^8.6.0",
    "node-gyp": "^12.2.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-native": "0.84.1",
    "react-native-feather": "^1.1.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-get-random-values": "~2.0.0",
    "react-native-linear-gradient": "^2.6.2",
    "react-native-markdown-display": "^7.0.0-alpha.2",
    "react-native-modal-datetime-picker": "^18.0.0",
    "react-native-reanimated": "~4.2.2",
    "react-native-reanimated-carousel": "^4.0.3",
    "react-native-rss-parser": "^1.5.1",
    "react-native-safe-area-context": "5.7.0",
    "react-native-screens": "~4.24.0",
    "react-native-style-utilities": "^1.0.1",
    "react-native-svg": "15.15.3",
    "react-native-view-shot": "4.0.3",
    "react-native-web": "~0.21.2",
    "semver": "^7.5.2",
    "use-debounce": "^10.1.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@babel/preset-react": "^7.18.6",
    "@expo/config-types": "^55.0.5",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react": "^16.3.2",
    "@testing-library/react-hooks": "^8.0.1",
    "@testing-library/react-native": "^13.3.3",
    "@testing-library/user-event": "^14.6.1",
    "@types/i18n-js": "^4.0.1",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.14.195",
    "@types/react": "~19.2.14",
    "@types/react-native": "~0.73.0",
    "@types/uuid": "^11.0.0",
    "jest": "^30.3.0",
    "jest-expo": "^55.0.10",
    "mockdate": "^3.0.5",
    "sharp": "^0.34.0",
    "typescript": "^5.9.3"
  },
  "private": true
}
